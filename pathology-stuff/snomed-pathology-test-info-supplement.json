      "code": "requiredSpecimen",
      "description": "Specimen requirements for the test, as described in the RCPA Manual.",
      "type": "string"
    }
  ],
  "concept": [
    {
      "code": "49466006",
      "display": "Adrenocorticotropic hormone measurement",
      "property": [
        {
          "code": "pathologyTestsExplainedUrl",
