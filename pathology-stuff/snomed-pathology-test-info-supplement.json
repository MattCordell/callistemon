        },
        {
          "code": "requiredSpecimen",
          "valueString": "1 mL arterial blood collected anaerobically in a heparinised syringe and transported rapidly to the laboratory in a capped syringe with the needle removed. An appropriately collected 'arterialised' capillary blood specimen may have values close to those of arterial blood. Fractional concentration of inspired O2 [FiO2] should be specified on request form."
        }
      ]
    },
