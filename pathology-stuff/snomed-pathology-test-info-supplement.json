      "type": "string"
    },
    {
      "code": "rcpaManualUrl",
      "description": "URL to the corresponding entry in the RCPA Manual (rcpa.edu.au), providing clinical guidance on test selection and interpretation for practitioners.",
      "type": "string"
    },
