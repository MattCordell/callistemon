          "valueString": "https://www.rcpa.edu.au/Manuals/RCPA-Manual/Pathology-Tests/A/ACTH"
        },
        {
          "code": "requiredSpecimen",
          "valueString": "5 mL blood in EDTA tube, collected on ice; plasma separated and frozen immediately. Collect sample between 0800-0900 h."
        }
      ]
    },
